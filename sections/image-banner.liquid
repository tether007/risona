{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image_height = 800
  assign image_width = 1920
-%}

{%- comment -%} Preload hero image for LCP performance {%- endcomment -%}
{%- if section.settings.image != blank -%}
  <link
    rel="preload"
    as="image"
    href="{{ section.settings.image | image_url: width: 1920 }}"
    imagesrcset="
      {{ section.settings.image | image_url: width: 750 }} 750w,
      {{ section.settings.image | image_url: width: 1100 }} 1100w,
      {{ section.settings.image | image_url: width: 1500 }} 1500w,
      {{ section.settings.image | image_url: width: 1920 }} 1920w
    "
    imagesizes="100vw"
  >
{%- endif -%}

<style>
  /* ── RISONA IMAGE BANNER ── */
  :root {
    --risona-red: #6B1212;
    --risona-red-mid: #8B1A1A;
    --risona-gold: #C9A96E;
    --risona-cream: #FAF6F1;
    --risona-dark: #1a0808;
    --risona-white: #ffffff;
  }

  .risona-hero {
    position: relative;
    width: 100%;
    height: 0;
    /* 800 / 1920 = 41.667% — maintains exact 1920×800 aspect ratio */
    padding-bottom: 41.667%;
    overflow: hidden;
    background: var(--risona-dark);
    margin-top: -1px; /* Seamless connection with navbar — no gap */
  }

  /* ── IMAGE ── */
  .risona-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .risona-hero__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .risona-hero__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── GRADIENT OVERLAY ── */
  .risona-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(26, 8, 8, 0.68) 0%,
      rgba(107, 18, 18, 0.42) 35%,
      rgba(0, 0, 0, 0.18) 70%,
      rgba(0, 0, 0, 0.08) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* ── CONTENT WRAPPER ── */
  .risona-hero__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    padding: 60px 5vw;
  }

  .risona-hero__inner {
    max-width: 580px;
    opacity: 0;
    transform: translateY(24px);
    animation: risona-hero-reveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  @keyframes risona-hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── EYEBROW ── */
  .risona-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .risona-hero__eyebrow-line {
    width: 32px;
    height: 1px;
    background: var(--risona-gold);
  }

  .risona-hero__eyebrow-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--risona-gold);
    font-weight: 400;
  }

  /* ── HEADING ── */
  .risona-hero__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 4.5vw, 60px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--risona-white);
    margin: 0 0 14px;
    letter-spacing: 0.02em;
  }

  .risona-hero__heading em {
    font-style: italic;
    color: var(--risona-gold);
  }

  /* ── SUBTEXT ── */
  .risona-hero__text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.78);
    font-weight: 300;
    margin: 0 0 32px;
    line-height: 1.8;
    max-width: 440px;
  }

  /* ── BUTTONS ── */
  .risona-hero__buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .risona-hero__btn-primary {
    display: inline-block;
    padding: 13px 34px;
    background: var(--risona-red);
    color: var(--risona-white);
    font-family: 'Cormorant Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--risona-red);
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  .risona-hero__btn-primary:hover {
    background: transparent;
    color: var(--risona-white);
    border-color: var(--risona-gold);
  }

  .risona-hero__btn-secondary {
    display: inline-block;
    padding: 13px 34px;
    background: transparent;
    color: var(--risona-white);
    font-family: 'Cormorant Garamond', serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 400;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.4);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .risona-hero__btn-secondary:hover {
    border-color: var(--risona-gold);
    color: var(--risona-gold);
  }

  /* ── DECORATIVE CORNER ── */
  .risona-hero__corner {
    position: absolute;
    top: 24px;
    left: 5vw;
    z-index: 3;
    width: 40px;
    height: 40px;
    pointer-events: none;
  }

  .risona-hero__corner::before,
  .risona-hero__corner::after {
    content: '';
    position: absolute;
    background: var(--risona-gold);
    opacity: 0.45;
  }

  .risona-hero__corner::before {
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
  }

  .risona-hero__corner::after {
    top: 0;
    left: 0;
    width: 1px;
    height: 100%;
  }

  /* ── LOGO WATERMARK ── */
  .risona-hero__watermark {
    position: absolute;
    bottom: 36px;
    right: 5vw;
    z-index: 2;
    opacity: 0.15;
    pointer-events: none;
  }

  .risona-hero__watermark svg {
    width: 120px;
    height: auto;
  }

  /* ── RESPONSIVE: TABLET ── */
  @media screen and (max-width: 990px) {
    .risona-hero {
      padding-bottom: 50%;
    }

    .risona-hero__content {
      padding: 48px 5vw;
    }

    .risona-hero__inner {
      max-width: 480px;
    }
  }

  /* ── RESPONSIVE: MOBILE ── */
  @media screen and (max-width: 749px) {
    .risona-hero {
      padding-bottom: 100%; /* Taller on mobile for readability */
    }

    .risona-hero__content {
      padding: 40px 6vw;
      align-items: flex-end;
      padding-bottom: 48px;
    }

    .risona-hero__inner {
      max-width: 100%;
    }

    .risona-hero__heading {
      font-size: clamp(28px, 8vw, 40px);
    }

    .risona-hero__watermark {
      display: none;
    }

    .risona-hero__corner {
      width: 28px;
      height: 28px;
      top: 16px;
      left: 4vw;
    }
  }
</style>

<section
  class="risona-hero"
  id="RisonaBanner-{{ section.id }}"
  role="banner"
  aria-label="{{ section.settings.heading_text | default: 'RISONA — Premium Anti-Tarnish Jewellery' | escape }}"
>
  {%- comment -%} Decorative corner accent {%- endcomment -%}
  <div class="risona-hero__corner" aria-hidden="true"></div>

  {%- comment -%} ── HERO IMAGE ── {%- endcomment -%}
  <div class="risona-hero__media">
    {%- if section.settings.image != blank -%}
      {%- assign img_alt = section.settings.image.alt | default: section.settings.heading_text | default: shop.name | append: ' — Hero Banner' -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          width: image_width,
          height: image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1920',
          fetchpriority: 'high',
          loading: 'eager',
          decoding: 'async',
          alt: img_alt
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%} Gradient overlay for text legibility {%- endcomment -%}
  <div class="risona-hero__overlay" aria-hidden="true"></div>

  {%- comment -%} ── CONTENT ── {%- endcomment -%}
  <div class="risona-hero__content page-width">
    <div class="risona-hero__inner">
      {%- if section.settings.eyebrow_text != blank -%}
        <div class="risona-hero__eyebrow">
          <span class="risona-hero__eyebrow-line" aria-hidden="true"></span>
          <span class="risona-hero__eyebrow-text">{{ section.settings.eyebrow_text }}</span>
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="risona-hero__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h1>

          {%- when 'text' -%}
            <p class="risona-hero__text" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </p>

          {%- when 'buttons' -%}
            <div class="risona-hero__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  href="{{ block.settings.button_link_1 | default: '#' }}"
                  class="risona-hero__btn-primary"
                  {% if block.settings.button_link_1 == blank %}aria-disabled="true"{% endif %}
                >
                  {{ block.settings.button_label_1 | escape }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  href="{{ block.settings.button_link_2 | default: '#' }}"
                  class="risona-hero__btn-secondary"
                  {% if block.settings.button_link_2 == blank %}aria-disabled="true"{% endif %}
                >
                  {{ block.settings.button_label_2 | escape }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} RISONA watermark {%- endcomment -%}
  <div class="risona-hero__watermark" aria-hidden="true">
    <svg viewBox="0 0 220 60" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="RISONA">
      <text x="0" y="46" font-family="'Cormorant Garamond', serif" font-size="48" font-weight="300" letter-spacing="8" fill="white">RISONA</text>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "RISONA Image Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image",
      "info": "Recommended: 1920 × 800px. Use a high-quality image that represents your brand."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "New Collection",
      "info": "Small accent text above the heading."
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "SEO alt heading",
      "default": "RISONA — Premium Anti-Tarnish Jewellery",
      "info": "Used for image alt text and accessibility. Describe the banner content for search engines."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Crafted to <em>Last</em> Forever",
          "label": "Heading",
          "info": "Wrap words in <em> tags for gold italic accent."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Anti-tarnish jewellery designed for the modern woman. Timeless elegance that endures.",
          "label": "Text"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Shop Now",
          "label": "Button 1 label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "Explore Collection",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RISONA Image Banner",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
