<style>
  .risona-catgrid-section {
    position: relative;
    z-index: 0;
    isolation: isolate;
    background: #fff;
    padding: 40px 0 48px;
    overflow: hidden;
  }

  .risona-catgrid__heading {
    font-family: 'Cormorant Garamond', serif;
    text-align: center;
    color: #6B1212;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.04em;
    margin: 0 0 28px;
  }

  .risona-catgrid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 10vw;
    gap: 4px;
    padding: 0 12px;
    max-width: 1200px;
    margin: 0 auto;
    grid-template-areas:
      "a1 a1 a2 a2 a2 a2"
      "a1 a1 a2 a2 a2 a2"
      "a1 a1 a2 a2 a2 a2"
      "a1 a1 a3 a3 a4 a4"
      "a1 a1 a3 a3 a4 a4"
      "a5 a5 a5 a6 a6 a6"
      "a5 a5 a5 a6 a6 a6"
      "a5 a5 a5 a6 a6 a6"
      "a7 a7 a8 a8 a8 a8"
      "a7 a7 a8 a8 a8 a8"
      "a7 a7 a8 a8 a8 a8";
  }

  .risona-catgrid__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    transform: translate3d(0, 0, 0);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.79);
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1),
                box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .risona-catgrid__card:hover {
    transform: translate3d(0, -3px, 0) scale(1.015);
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.79);
    z-index: 2;
  }

  .risona-catgrid__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .risona-catgrid__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5f0f0, #e8dede);
  }

  .risona-catgrid__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .risona-catgrid__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 48px 16px 16px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.2) 55%, transparent 100%);
    pointer-events: none;
  }

  .risona-catgrid__label {
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 400;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .risona-catgrid__link {
    position: absolute;
    inset: 0;
    z-index: 1;
    text-decoration: none;
    color: transparent;
    font-size: 0;
  }

  .risona-catgrid__link:focus-visible {
    outline: 2px solid #C9A96E;
    outline-offset: -2px;
    border-radius: 12px;
  }

  @media (max-width: 989px) {
    .risona-catgrid {
      grid-auto-rows: 14vw;
    }
  }

  @media (max-width: 749px) {
    .risona-catgrid-section {
      padding: 32px 0 36px;
    }

    .risona-catgrid__heading {
      font-size: 24px;
      margin-bottom: 24px;
    }

    .risona-catgrid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 34vw;
      gap: 4px;
      padding: 0 8px;

      grid-template-areas:
        "a1 a2"
        "a1 a2"
        "a3 a2"
        "a3 a4"
        "a5 a5"
        "a5 a5"
        "a6 a7"
        "a6 a8"
        "a6 a8";
    }

    .risona-catgrid__card {
      border-radius: 8px;
      box-shadow: 0 4px 10px rgba(0,0,0,.2);
    }

    .risona-catgrid__overlay {
      padding: 28px 10px 10px;
    }

    .risona-catgrid__label {
      font-size: 14px;
    }

    .risona-catgrid__link:focus-visible {
      border-radius: 8px;
    }
  }
  
</style>

<section class="risona-catgrid-section" id="RisonaCatGrid-{{ section.id }}" aria-labelledby="RisonaCatHeading-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="risona-catgrid__heading" id="RisonaCatHeading-{{ section.id }}">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <nav class="risona-catgrid" aria-label="Product categories">
    {%- for block in section.blocks -%}
      <div class="risona-catgrid__card" style="grid-area: a{{ forloop.index }};" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 900
            | image_tag:
              class: 'risona-catgrid__img',
              loading: 'lazy',
              decoding: 'async',
              sizes: '(max-width: 749px) 50vw, 25vw',
              widths: '300, 450, 600, 900',
              alt: block.settings.label
          }}
        {%- else -%}
          <div class="risona-catgrid__placeholder">
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <div class="risona-catgrid__overlay">
          <h3 class="risona-catgrid__label">{{ block.settings.label }}</h3>
        </div>
        <a href="{{ block.settings.link | default: '#' }}" class="risona-catgrid__link" aria-label="Shop {{ block.settings.label | escape }}">
          {{ block.settings.label }}
        </a>
      </div>
    {%- endfor -%}
  </nav>
</section>

{% schema %}
{
  "name": "RISONA Category Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop By Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image",
          "info": "Use high-quality lifestyle or product images."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RISONA Category Grid",
      "settings": {
        "heading": "Shop By Category"
      },
      "blocks": [
        { "type": "category", "settings": { "label": "Rings" } },
        { "type": "category", "settings": { "label": "Earrings" } },
        { "type": "category", "settings": { "label": "Pendants" } },
        { "type": "category", "settings": { "label": "Chains" } },
        { "type": "category", "settings": { "label": "Necklaces" } },
        { "type": "category", "settings": { "label": "Bracelets" } },
        { "type": "category", "settings": { "label": "Bangles" } },
        { "type": "category", "settings": { "label": "Anklets" } }
      ]
    }
  ]
}
{% endschema %}
