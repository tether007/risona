{{ 'bestsellers.css' | asset_url | stylesheet_tag }}

<section class="bestsellers-section" style="background:{{ section.settings.bg_color }}">
  <div class="bestsellers-wrap">

    {% if section.settings.heading != blank %}
      <h2 class="bestsellers-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="bestsellers-grid" style="--cols:{{ section.settings.columns_desktop }}">
      {% assign collection = collections[section.settings.collection] %}

      {% for product in collection.products limit: section.settings.products_to_show %}
        {% assign compare_price = product.compare_at_price %}
        {% assign price_dropped = false %}
        {% if compare_price > product.price %}
          {% assign price_dropped = true %}
        {% endif %}

        {% assign primary_image = product.featured_image %}
        {% assign hover_image = product.images[1] | default: product.featured_image %}

        {% comment %} Rating: reads from product metafields if you set them up (reviews.rating / reviews.rating_count).
             Falls back to nothing shown if not set. Swap this block for your review app's snippet if you use one. {% endcomment %}
        {% assign rating = product.metafields.reviews.rating.value.rating %}
        {% assign rating_count = product.metafields.reviews.rating_count %}

        <div class="product-card" data-product-card>

          <a href="{{ product.url }}" class="product-card__media">

            {% if product.tags contains 'bestseller' %}
              <span class="badge badge--bestseller">Bestseller</span>
            {% endif %}

            <button type="button" class="wishlist-btn" aria-label="Add to wishlist" data-wishlist-toggle>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 21s-7.5-4.6-10-9.3C.4 8 2 4.5 5.6 4c2.1-.3 4 .8 6.4 3.4C14.4 4.8 16.3 3.7 18.4 4c3.6.5 5.2 4 3.6 7.7C19.5 16.4 12 21 12 21Z"/>
              </svg>
            </button>

            <img
              class="product-card__img product-card__img--primary"
              src="{{ primary_image | image_url: width: 600 }}"
              alt="{{ primary_image.alt | default: product.title }}"
              loading="lazy"
              width="600"
              height="{{ 600 | divided_by: primary_image.aspect_ratio | default: 600 }}"
            >
            <img
              class="product-card__img product-card__img--hover"
              src="{{ hover_image | image_url: width: 600 }}"
              alt=""
              loading="lazy"
              width="600"
              height="{{ 600 | divided_by: hover_image.aspect_ratio | default: 600 }}"
            >
          </a>

          <div class="product-card__body">

            {% if rating %}
              <div class="product-card__rating">
                <span class="star">&#9733;</span>
                <span>{{ rating | round: 1 }}</span>
                {% if rating_count %}<span class="rating-count">| {{ rating_count }}</span>{% endif %}
              </div>
            {% endif %}

            <div class="product-card__price">
              <span class="price-now">{{ product.price | money }}</span>
              {% if price_dropped %}
                <span class="price-was">{{ compare_price | money }}</span>
              {% endif %}
            </div>

            <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>

            {% if price_dropped %}
              <span class="price-drop-label">PRICE DROP!</span>
            {% endif %}

            <product-form-mini data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
              <button
                type="button"
                class="add-to-cart-btn"
                data-add-to-cart
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                {% unless product.available %}disabled{% endunless %}
              >
                {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
              </button>
            </product-form-mini>

          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.view_more_url != blank %}
      <div class="bestsellers-viewmore">
        <a href="{{ section.settings.view_more_url }}" class="view-more-btn">View More</a>
      </div>
    {% endif %}

  </div>
</section>

<script>
  (function () {
    function addToCart(button) {
      var variantId = button.getAttribute('data-variant-id');
      if (!variantId || button.disabled) return;

      var originalText = button.textContent;
      button.disabled = true;
      button.textContent = 'Adding...';

      fetch('{{ routes.cart_add_url }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Add to cart failed');
          return res.json();
        })
        .then(function () {
          button.textContent = 'Added ✓';
          document.dispatchEvent(new CustomEvent('cart:updated'));
          setTimeout(function () {
            button.textContent = originalText;
            button.disabled = false;
          }, 1500);
        })
        .catch(function () {
          button.textContent = 'Error — try again';
          setTimeout(function () {
            button.textContent = originalText;
            button.disabled = false;
          }, 1800);
        });
    }

    document.querySelectorAll('[data-add-to-cart]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        addToCart(btn);
      });
    });

    document.querySelectorAll('[data-wishlist-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        btn.classList.toggle('is-active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Bestsellers Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FBF3E7"
    },
    {
      "type": "url",
      "id": "view_more_url",
      "label": "\"View More\" link"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers Grid",
      "category": "Product"
    }
  ]
}
{% endschema %}
