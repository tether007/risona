{% schema %}
{
  "name": "Risona Footer",
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Background colour",
      "default": "#f5f2f2"
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "Dark mode (light text for dark backgrounds)",
      "info": "Enable this when using a dark background colour so all text automatically switches to light colours.",
      "default": false
    },
    {
      "type": "header",
      "content": "Column 1 — Quick Links"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Heading",
      "default": "Quick links"
    },
    {
      "type": "link_list",
      "id": "col1_menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Column 2 — Info"
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Heading",
      "default": "Info"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Column 3 — Contact"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Heading",
      "default": "Contact us"
    },
    {
      "type": "text",
      "id": "bis_number",
      "label": "BIS / certification number",
      "default": "BIS : HM/C - 6290031216"
    },
    {
      "type": "text",
      "id": "contact_intro",
      "label": "Intro line",
      "default": "For any suggestions, queries or complaints please contact us:"
    },
    {
      "type": "text",
      "id": "company_name",
      "label": "Company name",
      "default": "Risona Jewels Private Limited"
    },
    {
      "type": "textarea",
      "id": "company_address",
      "label": "Address",
      "default": "Third Floor, Magnum Vista, Raghuvanahalli, Bangalore 560062"
    },
    {
      "type": "text",
      "id": "chat_link",
      "label": "Chat link URL"
    },
    {
      "type": "text",
      "id": "chat_label",
      "label": "Chat link label",
      "default": "Chat with us (Recommended for quick support)"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "9228837724 (10:00 AM – 6:30 PM)"
    },
    {
      "type": "text",
      "id": "ticket_link",
      "label": "Ticket / support link URL"
    },
    {
      "type": "text",
      "id": "ticket_label",
      "label": "Ticket link label",
      "default": "Raise a ticket (For non-urgent requests)"
    },
    {
      "type": "header",
      "content": "Column 4 — App Download"
    },
    {
      "type": "checkbox",
      "id": "show_app_section",
      "label": "Show app download column",
      "default": false
    },
    {
      "type": "text",
      "id": "app_heading",
      "label": "Column heading",
      "default": "Download Our App"
    },
    {
      "type": "textarea",
      "id": "app_description",
      "label": "Description",
      "default": "Shop new arrivals, track orders & get exclusive app-only offers."
    },
    {
      "type": "url",
      "id": "playstore_link",
      "label": "Google Play link"
    },
    {
      "type": "url",
      "id": "appstore_link",
      "label": "App Store link"
    },
    {
      "type": "header",
      "content": "Email Subscribe"
    },
    {
      "type": "text",
      "id": "subscribe_label",
      "label": "Subscribe heading",
      "default": "Subscribe for exclusive offers and updates!"
    },
    {
      "type": "text",
      "id": "subscribe_placeholder",
      "label": "Input placeholder",
      "default": "Email"
    },
    {
      "type": "header",
      "content": "Payment Methods"
    },
    {
      "type": "checkbox",
      "id": "show_payment_methods",
      "label": "Show payment methods",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_label",
      "label": "Label text",
      "default": "We Accept"
    },
    {
      "type": "checkbox",
      "id": "show_visa",
      "label": "Show Visa",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mastercard",
      "label": "Show Mastercard",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_amex",
      "label": "Show American Express",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_upi",
      "label": "Show UPI",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_rupay",
      "label": "Show RuPay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cod",
      "label": "Show Cash on Delivery (COD)",
      "default": false
    },
    {
      "type": "header",
      "content": "Social Icons"
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "Label before icons",
      "default": "Follow us on",
      "info": "Leave blank to hide the label. Social links are managed in Theme Settings → Social Media."
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "cin_number",
      "label": "CIN / registration number",
      "info": "e.g. CIN: L72900KA2011PLC059678 — displayed below the copyright line."
    },
    {
      "type": "text",
      "id": "copyright_links",
      "label": "Extra copyright links (HTML allowed)",
      "info": "e.g. <a href='/policies/privacy-policy'>Privacy</a> · <a href='/policies/terms-of-service'>Terms</a>"
    }
  ]
}
{% endschema %}
