<style>
  :root {
    --risona-red: #6B1212;
    --risona-red-light: #fdf0f0;
    --risona-gold: #C9A96E;
    --risona-dark: #1a0808;
    --risona-muted: #7a3535;
    --risona-border: #e8d5d5;
  }

  /* ── FOOTER WRAPPER ── */
  .risona-footer {
    background: {{ section.settings.footer_bg_color }};
    border-top: 2px solid var(--risona-border);
    font-family: 'Outfit', sans-serif;
    color: var(--risona-dark);
  }

  /* ── DARK MODE OVERRIDES (applied when dark_mode is enabled) ── */
  .risona-footer--dark {
    --risona-dark: #f0e8e8;
    --risona-muted: #c0a0a0;
    --risona-border: rgba(255,255,255,0.1);
    border-top-color: rgba(201,169,110,0.3);
  }
  .risona-footer--dark .risona-footer__col-title   { color: #fff; }
  .risona-footer--dark .risona-footer__links a     { color: #d4b8b8; }
  .risona-footer--dark .risona-footer__links a:hover { color: var(--risona-gold); }
  .risona-footer--dark .risona-footer__contact-body { color: #c8b0b0; }
  .risona-footer--dark .risona-footer__contact-body strong { color: #fff; }
  .risona-footer--dark .risona-footer__contact-body address { color: #b8a0a0; }
  .risona-footer--dark .risona-footer__contact-item { color: #c8b0b0; }
  .risona-footer--dark .risona-footer__app-desc    { color: #b8a0a0; }
  .risona-footer--dark .risona-footer__subscribe-label { color: #f0e8e8; }
  .risona-footer--dark .risona-footer__subscribe-form  {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.14);
  }
  .risona-footer--dark .risona-footer__subscribe-form input[type="email"] { color: #fff; }
  .risona-footer--dark .risona-footer__subscribe-form input[type="email"]::placeholder { color: rgba(255,255,255,0.35); }
  .risona-footer--dark .risona-footer__payment-label { color: rgba(255,255,255,0.5); }
  .risona-footer--dark .risona-footer__payment-icon  { border-color: rgba(255,255,255,0.12); }
  .risona-footer--dark .risona-footer__social-label  { color: rgba(255,255,255,0.5); }
  .risona-footer--dark .risona-footer__social a {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.14);
    color: #d4b8b8;
  }
  .risona-footer--dark .risona-footer__social a:hover {
    background: var(--risona-red);
    border-color: var(--risona-red);
    color: #fff;
  }
  .risona-footer--dark .risona-footer__copyright {
    color: rgba(255,255,255,0.4);
    border-top-color: rgba(255,255,255,0.08);
  }

  /* ── TOP GRID: 3-col default, 4-col when app section is on ── */
  .risona-footer__top {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 3rem;
    padding: 4rem 5rem 3.5rem;
    border-bottom: 1px solid var(--risona-border);
  }
  .risona-footer__top--4col { grid-template-columns: 1fr 1fr 1.1fr 1.3fr; }

  @media screen and (max-width: 1100px) {
    .risona-footer__top--4col { grid-template-columns: 1fr 1fr; }
  }
  @media screen and (max-width: 900px) {
    .risona-footer__top { grid-template-columns: 1fr 1fr; padding: 3rem 2rem; }
    .risona-footer__col--contact { grid-column: 1 / -1; }
  }
  @media screen and (max-width: 600px) {
    .risona-footer__top { grid-template-columns: 1fr; gap: 2.5rem; }
    .risona-footer__col--contact,
    .risona-footer__col--app { grid-column: 1; }
  }

  /* ── COLUMN HEADING ── */
  .risona-footer__col-title {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--risona-dark);
    margin: 0 0 1.4rem;
    padding-bottom: 0.7rem;
    border-bottom: 1.5px solid var(--risona-red);
    display: inline-block;
  }

  /* ── LINK LIST ── */
  .risona-footer__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .risona-footer__links a {
    font-size: 13px; font-weight: 400; letter-spacing: 0.04em;
    color: #4a2020; text-decoration: none;
    display: inline-block; position: relative;
    transition: color 0.2s;
  }
  .risona-footer__links a::before {
    content: ''; position: absolute; left: 0; bottom: -1px;
    width: 0; height: 1px; background: var(--risona-gold);
    transition: width 0.25s ease;
  }
  .risona-footer__links a:hover { color: var(--risona-red); }
  .risona-footer__links a:hover::before { width: 100%; }

  /* ── CONTACT COLUMN ── */
  .risona-footer__contact-body { font-size: 13px; line-height: 1.7; color: #4a2020; }
  .risona-footer__contact-body .bis {
    font-size: 11px; letter-spacing: 0.12em; color: var(--risona-muted);
    margin-bottom: 1rem; display: block;
  }
  .risona-footer__contact-body p { margin: 0 0 0.9rem; }
  .risona-footer__contact-body strong { font-weight: 600; color: var(--risona-dark); }
  .risona-footer__contact-body address {
    font-style: normal; margin-bottom: 1.1rem; font-size: 12.5px; color: #5a2828;
  }
  .risona-footer__contact-item {
    display: flex; align-items: baseline; gap: 0.5rem;
    margin-bottom: 0.55rem; font-size: 13px; color: #4a2020;
  }
  .risona-footer__contact-item .dash { color: var(--risona-gold); font-weight: 700; flex-shrink: 0; }
  .risona-footer__contact-item a {
    color: var(--risona-red); text-decoration: underline;
    text-underline-offset: 2px; text-decoration-color: var(--risona-border);
    transition: text-decoration-color 0.2s;
  }
  .risona-footer__contact-item a:hover { text-decoration-color: var(--risona-gold); }

  /* ── APP DOWNLOAD COLUMN ── */
  .risona-footer__app-desc {
    font-size: 12.5px; line-height: 1.6; color: #5a2828; margin: 0 0 1.2rem;
  }
  .risona-footer__app-badges { display: flex; flex-direction: column; gap: 0.65rem; align-items: flex-start; }
  .risona-footer__app-badge {
    display: inline-flex; align-items: center; gap: 0.65rem;
    background: #111; color: #fff; border-radius: 8px;
    padding: 0.45rem 1rem 0.45rem 0.75rem;
    text-decoration: none; border: 1px solid rgba(255,255,255,0.14);
    transition: background 0.2s, transform 0.15s; min-width: 148px;
  }
  .risona-footer__app-badge:hover { background: #222; transform: translateY(-1px); }
  .risona-footer__app-badge svg { width: 20px; height: 20px; flex-shrink: 0; }
  .risona-footer__app-badge-text { display: flex; flex-direction: column; line-height: 1.25; }
  .risona-footer__app-badge-sub { font-size: 9px; letter-spacing: 0.04em; opacity: 0.72; font-weight: 400; }
  .risona-footer__app-badge-main { font-size: 13px; font-weight: 600; }

  /* ── BOTTOM BAR ── */
  .risona-footer__bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding: 2.2rem 5rem; gap: 2rem; flex-wrap: wrap;
  }
  @media screen and (max-width: 900px) {
    .risona-footer__bottom { padding: 2rem; flex-direction: column; align-items: flex-start; }
  }

  /* ── EMAIL SUBSCRIBE ── */
  .risona-footer__subscribe-label {
    font-size: 13px; font-weight: 500; letter-spacing: 0.06em;
    color: var(--risona-dark); margin-bottom: 0.85rem;
  }
  .risona-footer__subscribe-form {
    display: flex; align-items: center;
    border: 1px solid var(--risona-border); border-radius: 4px;
    background: #fff; overflow: hidden; width: 300px; max-width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .risona-footer__subscribe-form:focus-within {
    border-color: var(--risona-gold); box-shadow: 0 0 0 1px var(--risona-gold);
  }
  .risona-footer__subscribe-form input[type="email"] {
    flex: 1; border: none; outline: none; background: transparent;
    padding: 0.8rem 1rem; font-family: 'Outfit', sans-serif;
    font-size: 13px; color: var(--risona-dark);
  }
  .risona-footer__subscribe-form input[type="email"]::placeholder { color: #b08080; font-size: 13px; }
  .risona-footer__subscribe-btn {
    background: var(--risona-red); color: #fff; border: none;
    padding: 0.8rem 1.1rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s; flex-shrink: 0;
  }
  .risona-footer__subscribe-btn:hover { background: #7a1414; }
  .risona-footer__subscribe-btn svg {
    width: 16px; height: 16px; stroke: #fff; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  /* ── PAYMENT METHODS ── */
  .risona-footer__payment { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; }
  .risona-footer__payment-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--risona-muted); white-space: nowrap;
  }
  .risona-footer__payment-icons { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
  .risona-footer__payment-icon {
    height: 26px; border-radius: 4px; overflow: hidden;
    border: 1px solid var(--risona-border); background: #fff;
    display: flex; align-items: center; justify-content: center; padding: 0 5px;
  }
  .risona-footer__payment-icon svg { height: 16px; width: auto; display: block; }

  /* ── SOCIAL WITH LABEL ── */
  .risona-footer__right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.45rem; }
  @media screen and (max-width: 900px) { .risona-footer__right { align-items: flex-start; } }
  .risona-footer__social-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--risona-muted);
  }
  .risona-footer__social { display: flex; align-items: center; gap: 0.6rem; }
  .risona-footer__social a {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 6px;
    border: 1px solid var(--risona-border); background: #fff;
    color: var(--risona-dark); text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .risona-footer__social a:hover { background: var(--risona-red); border-color: var(--risona-red); color: #fff; }
  .risona-footer__social svg { width: 15px; height: 15px; fill: currentColor; }

  /* ── COPYRIGHT ── */
  .risona-footer__copyright {
    text-align: center; font-size: 11px; letter-spacing: 0.08em;
    color: var(--risona-muted); padding: 1rem 5rem 1.5rem;
    border-top: 1px solid var(--risona-border);
    display: flex; flex-direction: column; gap: 0.3rem; align-items: center;
  }
  .risona-footer__copyright a { color: var(--risona-gold); text-decoration: none; }
  .risona-footer__copyright a:hover { text-decoration: underline; }
  .risona-footer__cin { font-size: 10px; letter-spacing: 0.06em; opacity: 0.6; }
</style>

<footer class="risona-footer{% if section.settings.dark_mode %} risona-footer--dark{% endif %}" role="contentinfo">

  <!-- ── TOP COLUMNS ── -->
  <div class="risona-footer__top{% if section.settings.show_app_section %} risona-footer__top--4col{% endif %}">

    <!-- Column 1: Quick Links -->
    <div class="risona-footer__col">
      <h3 class="risona-footer__col-title">{{ section.settings.col1_title }}</h3>
      <ul class="risona-footer__links">
        {%- assign col1_menu = linklists[section.settings.col1_menu] -%}
        {%- for link in col1_menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <!-- Column 2: Info -->
    <div class="risona-footer__col">
      <h3 class="risona-footer__col-title">{{ section.settings.col2_title }}</h3>
      <ul class="risona-footer__links">
        {%- assign col2_menu = linklists[section.settings.col2_menu] -%}
        {%- for link in col2_menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <!-- Column 3: Contact -->
    <div class="risona-footer__col risona-footer__col--contact">
      <h3 class="risona-footer__col-title">{{ section.settings.col3_title }}</h3>
      <div class="risona-footer__contact-body">
        {%- if section.settings.bis_number != blank -%}
          <span class="bis">{{ section.settings.bis_number }}</span>
        {%- endif -%}
        {%- if section.settings.contact_intro != blank -%}
          <p>{{ section.settings.contact_intro }}</p>
        {%- endif -%}
        {%- if section.settings.company_name != blank -%}
          <p><strong>{{ section.settings.company_name }}</strong></p>
        {%- endif -%}
        {%- if section.settings.company_address != blank -%}
          <address>{{ section.settings.company_address }}</address>
        {%- endif -%}
        {%- if section.settings.chat_link != blank -%}
          <div class="risona-footer__contact-item">
            <span class="dash">—</span>
            <a href="{{ section.settings.chat_link }}">{{ section.settings.chat_label | default: 'Chat with us' }}</a>
          </div>
        {%- endif -%}
        {%- if section.settings.phone_number != blank -%}
          <div class="risona-footer__contact-item">
            <span class="dash">—</span>
            <span>{{ section.settings.phone_number }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.ticket_link != blank -%}
          <div class="risona-footer__contact-item">
            <span class="dash">—</span>
            <a href="{{ section.settings.ticket_link }}">{{ section.settings.ticket_label | default: 'Raise a ticket' }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Column 4: App Download (conditional) -->
    {%- if section.settings.show_app_section -%}
      <div class="risona-footer__col risona-footer__col--app">
        <h3 class="risona-footer__col-title">{{ section.settings.app_heading | default: 'Download Our App' }}</h3>
        {%- if section.settings.app_description != blank -%}
          <p class="risona-footer__app-desc">{{ section.settings.app_description }}</p>
        {%- endif -%}
        <div class="risona-footer__app-badges">
          {%- if section.settings.playstore_link != blank -%}
            <a href="{{ section.settings.playstore_link }}" target="_blank" rel="noopener" class="risona-footer__app-badge">
              <!-- Google Play icon -->
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.18 1.05 13.5 11.37l-2.16 2.16L3.18 5.37A2.25 2.25 0 0 1 3.18 1.05z" fill="#EA4335"/>
                <path d="M1.5 2.25v19.5l10.5-9.75L1.5 2.25z" fill="#4285F4"/>
                <path d="M20.25 10.5 16.5 8.25 13.5 11.25l3 3 3.75-2.25a1.5 1.5 0 0 0 0-2.5z" fill="#FBBC05"/>
                <path d="M3.18 22.95 13.5 12.63l-2.16-2.16-8.16 8.16a2.25 2.25 0 0 0 3.18 3.18l-3.18-1.06z" fill="#34A853"/>
              </svg>
              <div class="risona-footer__app-badge-text">
                <span class="risona-footer__app-badge-sub">GET IT ON</span>
                <span class="risona-footer__app-badge-main">Google Play</span>
              </div>
            </a>
          {%- endif -%}
          {%- if section.settings.appstore_link != blank -%}
            <a href="{{ section.settings.appstore_link }}" target="_blank" rel="noopener" class="risona-footer__app-badge">
              <!-- Apple icon -->
              <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.14-2.18 1.27-2.16 3.79.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.37 2.79M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div class="risona-footer__app-badge-text">
                <span class="risona-footer__app-badge-sub">Download on the</span>
                <span class="risona-footer__app-badge-main">App Store</span>
              </div>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="risona-footer__bottom">

    <!-- Subscribe -->
    <div class="risona-footer__subscribe">
      <p class="risona-footer__subscribe-label">{{ section.settings.subscribe_label | default: 'Subscribe for exclusive offers and updates!' }}</p>
      {%- form 'customer', id: 'risona-footer-subscribe' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="risona-footer__subscribe-form">
          <input
            type="email" name="contact[email]"
            placeholder="{{ section.settings.subscribe_placeholder | default: 'Email' }}"
            autocorrect="off" autocapitalize="off"
            aria-label="{{ section.settings.subscribe_placeholder | default: 'Email' }}"
            required
          >
          <button type="submit" class="risona-footer__subscribe-btn" aria-label="Subscribe">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      {%- endform -%}
    </div>

    <!-- Payment Methods (conditional) -->
    {%- if section.settings.show_payment_methods -%}
      <div class="risona-footer__payment">
        {%- if section.settings.payment_label != blank -%}
          <span class="risona-footer__payment-label">{{ section.settings.payment_label }}</span>
        {%- endif -%}
        <div class="risona-footer__payment-icons">
          {%- if section.settings.show_visa -%}
            <div class="risona-footer__payment-icon" title="Visa">
              <svg viewBox="0 0 60 20" xmlns="http://www.w3.org/2000/svg" width="42" height="14">
                <rect width="60" height="20" fill="#1A1F71" rx="2"/>
                <text x="30" y="15" fill="white" font-family="Arial,sans-serif" font-size="14" font-weight="bold" text-anchor="middle" font-style="italic">VISA</text>
              </svg>
            </div>
          {%- endif -%}
          {%- if section.settings.show_mastercard -%}
            <div class="risona-footer__payment-icon" title="Mastercard">
              <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" width="38" height="24">
                <circle cx="15" cy="12" r="11" fill="#EB001B"/>
                <circle cx="23" cy="12" r="11" fill="#F79E1B"/>
                <path d="M19 3.8a11 11 0 0 1 0 16.4 11 11 0 0 1 0-16.4z" fill="#FF5F00"/>
              </svg>
            </div>
          {%- endif -%}
          {%- if section.settings.show_amex -%}
            <div class="risona-footer__payment-icon" title="American Express">
              <svg viewBox="0 0 52 18" xmlns="http://www.w3.org/2000/svg" width="50" height="16">
                <rect width="52" height="18" fill="#2E77BC" rx="2"/>
                <text x="26" y="13" fill="white" font-family="Arial,sans-serif" font-size="9.5" font-weight="bold" text-anchor="middle" letter-spacing="1">AMEX</text>
              </svg>
            </div>
          {%- endif -%}
          {%- if section.settings.show_upi -%}
            <div class="risona-footer__payment-icon" title="UPI">
              <svg viewBox="0 0 48 20" xmlns="http://www.w3.org/2000/svg" width="44" height="18">
                <rect width="48" height="20" fill="#fff" rx="2"/>
                <text x="10" y="14" fill="#097939" font-family="Arial,sans-serif" font-size="8.5" font-weight="bold">UPI</text>
                <rect x="28" y="4" width="3" height="12" rx="1" fill="#097939"/>
                <rect x="33" y="4" width="3" height="12" rx="1" fill="#FC4C02"/>
                <rect x="38" y="4" width="3" height="12" rx="1" fill="#097939"/>
              </svg>
            </div>
          {%- endif -%}
          {%- if section.settings.show_rupay -%}
            <div class="risona-footer__payment-icon" title="RuPay">
              <svg viewBox="0 0 58 20" xmlns="http://www.w3.org/2000/svg" width="54" height="18">
                <rect width="58" height="20" fill="#1B3E86" rx="2"/>
                <text x="29" y="14" fill="white" font-family="Arial,sans-serif" font-size="9" font-weight="bold" text-anchor="middle">RuPay</text>
              </svg>
            </div>
          {%- endif -%}
          {%- if section.settings.show_cod -%}
            <div class="risona-footer__payment-icon" title="Cash on Delivery">
              <svg viewBox="0 0 54 20" xmlns="http://www.w3.org/2000/svg" width="50" height="18">
                <rect width="54" height="20" fill="#2E7D32" rx="2"/>
                <text x="27" y="13.5" fill="white" font-family="Arial,sans-serif" font-size="8" font-weight="bold" text-anchor="middle">COD</text>
              </svg>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Social Icons with label -->
    <div class="risona-footer__right">
      {%- if section.settings.social_label != blank -%}
        <span class="risona-footer__social-label">{{ section.settings.social_label }}</span>
      {%- endif -%}
      <div class="risona-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
