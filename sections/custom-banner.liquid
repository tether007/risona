<style>
.banner-section {
  width: 100%;
}

.banner-container {
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}
.banner-link {
  display: block;
}

.banner-image {
  width: 100%;
  aspect-ratio: 1369 / 321;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.banner-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.banner-image .mobile-image {
  display: none;
}

@media screen and (max-width: 749px) {
  .banner-container {
    padding: 0 16px;
  }

  .banner-image {
    aspect-ratio: 16 / 9;
  }

  .banner-image .desktop-image {
    display: none;
  }

  .banner-image .mobile-image {
    display: block;
  }
}
</style>

<section class="banner-section">
  <div class="banner-container">

    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="banner-link">
    {% endif %}

    <div class="banner-image">

      {% if section.settings.desktop_image != blank %}
        {{
          section.settings.desktop_image
          | image_url: width: 1800
          | image_tag:
            class: 'desktop-image',
            loading: 'lazy',
            widths: '600,900,1200,1369,1800',
            sizes: '(min-width:990px) 1369px,100vw'
        }}
      {% endif %}

      {% if section.settings.mobile_image != blank %}
        {{
          section.settings.mobile_image
          | image_url: width: 900
          | image_tag:
            class: 'mobile-image',
            loading: 'lazy',
            widths: '375,550,750,900',
            sizes: '100vw'
        }}
      {% endif %}

    </div>

    {% if section.settings.link != blank %}
      </a>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Responsive Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}